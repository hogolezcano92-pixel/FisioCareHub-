{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile for patients and physiotherapists",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["patient", "physiotherapist", "admin"] },
        "name": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "phone": { "type": "string" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "specialty": { "type": "string" },
        "city": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["domicilio", "online", "ambos"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "name"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient specific data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "photoURL": { "type": "string", "format": "uri" },
        "history": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "name", "email"]
    },
    "Physiotherapist": {
      "title": "Physiotherapist",
      "description": "Physiotherapist specific data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "crefito": { "type": "string" },
        "specialty": { "type": "string" },
        "city": { "type": "string" },
        "serviceType": { "type": "string", "enum": ["domicilio", "online", "ambos"] },
        "photoURL": { "type": "string", "format": "uri" },
        "documents": { 
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "approved": { "type": "boolean" },
        "status": { "type": "string", "enum": ["pending_approval", "approved", "rejected"] }
      },
      "required": ["uid", "name", "email", "crefito", "specialty", "city", "serviceType"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Scheduled physiotherapy sessions",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "physioId": { "type": "string" },
        "problem": { "type": "string" },
        "specialty": { "type": "string" },
        "location": { "type": "string" },
        "desiredTime": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["waiting", "accepted", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "problem", "specialty", "status"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Payment records",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "commission": { "type": "number" },
        "patientId": { "type": "string" },
        "physioId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "paid", "failed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["amount", "commission", "patientId", "physioId", "status"]
    },
    "Triage": {
      "title": "Triage",
      "description": "Patient self-triage",
      "type": "object",
      "properties": {
        "patientId": { "type": "string" },
        "painLocation": { "type": "string" },
        "painDuration": { "type": "string" },
        "painIntensity": { "type": "integer", "minimum": 0, "maximum": 10 },
        "serviceType": { "type": "string", "enum": ["domicilio", "online"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["patientId", "painLocation", "painDuration", "painIntensity", "serviceType"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat messages between users and support",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["message", "appointment", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient profiles"
    },
    "/physiotherapists/{physioId}": {
      "schema": "Physiotherapist",
      "description": "Physiotherapist profiles"
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Scheduled sessions"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/triages/{triageId}": {
      "schema": "Triage",
      "description": "Triage results"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    }
  }
}
