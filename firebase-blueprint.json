{
  "entities": {
    "PatientExercise": {
      "title": "PatientExercise",
      "description": "Exercises prescribed by a physiotherapist to a patient.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "patient_id": { "type": "string", "format": "uuid", "description": "ID of the patient receiving the exercise." },
        "physio_id": { "type": "string", "format": "uuid", "description": "ID of the physiotherapist who prescribed the exercise." },
        "exercise_name": { "type": "string", "description": "Name of the exercise." },
        "description": { "type": "string", "description": "Instructions or description of the exercise." },
        "sets": { "type": "string", "description": "Number of sets." },
        "reps": { "type": "string", "description": "Number of repetitions." },
        "video_url": { "type": "string", "format": "uri", "description": "URL to a video demonstrating the exercise." },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["patient_id", "physio_id", "exercise_name"]
    },
    "LibraryMaterial": {
      "title": "LibraryMaterial",
      "description": "Educational materials available in the health library with structured clinical content.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "clinical_objective": { "type": "string", "description": "The clinical goal of this material." },
        "level": { "type": "string", "enum": ["beginner", "intermediate", "advanced"] },
        "type": { "type": "string", "enum": ["educational", "exercise", "alert"] },
        "price": { "type": "number" },
        "cover_image": { "type": "string", "format": "uri" },
        "file_url": { "type": "string", "format": "uri", "description": "Optional PDF URL if already generated." },
        "category": { "type": "string" },
        "sections": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": { "type": "string", "enum": ["text", "step-by-step", "image", "alert", "checklist"] },
              "content": { "type": "object" }
            }
          }
        },
        "is_premium": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "description", "category", "sections"]
    },
    "MaterialPurchase": {
      "title": "MaterialPurchase",
      "description": "Record of a material purchased by a patient.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "patient_id": { "type": "string", "format": "uuid" },
        "material_id": { "type": "string", "format": "uuid" },
        "purchased_at": { "type": "string", "format": "date-time" }
      },
      "required": ["patient_id", "material_id"]
    }
  },
  "firestore": {
    "patient_exercises": {
      "schema": "PatientExercise",
      "description": "Collection of exercises prescribed to patients."
    },
    "library_materials": {
      "schema": "LibraryMaterial",
      "description": "Collection of educational materials."
    },
    "material_purchases": {
      "schema": "MaterialPurchase",
      "description": "Collection of material purchases."
    }
  }
}
